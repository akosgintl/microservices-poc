# =============================================================================
# MICROSERVICES POC - ENVIRONMENT CONFIGURATION (EXAMPLE)
# =============================================================================
# Copy this file to .env and modify the values according to your needs.
# This file serves as a template with default/example values.
# =============================================================================

# =============================================================================
# INFRASTRUCTURE - APACHE KAFKA
# =============================================================================
# Kafka bootstrap servers (comma-separated list for multiple brokers)
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Kafka node configuration
KAFKA_NODE_ID=1
KAFKA_PROCESS_ROLES=broker,controller

# Kafka listeners and advertised listeners
KAFKA_LISTENERS=PLAINTEXT://0.0.0.0:9092,CONTROLLER://0.0.0.0:9093,PLAINTEXT_HOST://0.0.0.0:29092
KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://kafka:9092,PLAINTEXT_HOST://localhost:29092
KAFKA_LISTENER_SECURITY_PROTOCOL_MAP=CONTROLLER:PLAINTEXT,PLAINTEXT:PLAINTEXT,PLAINTEXT_HOST:PLAINTEXT

# Kafka controller configuration (KRaft mode)
KAFKA_CONTROLLER_QUORUM_VOTERS=1@kafka:9093
KAFKA_CONTROLLER_LISTENER_NAMES=CONTROLLER
KAFKA_INTER_BROKER_LISTENER_NAME=PLAINTEXT

# Kafka topic configuration
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1
KAFKA_TRANSACTION_STATE_LOG_REPLICATION_FACTOR=1
KAFKA_TRANSACTION_STATE_LOG_MIN_ISR=1
KAFKA_GROUP_INITIAL_REBALANCE_DELAY_MS=0

# Auto-create topics on first message (true/false)
KAFKA_AUTO_CREATE_TOPICS_ENABLE=true

# Kafka cluster ID (must be a valid base64 UUID)
CLUSTER_ID=base64-encoded-uuid


# =============================================================================
# INFRASTRUCTURE - KAFKA UI
# =============================================================================
# Kafka UI configuration for web management interface
KAFKA_CLUSTERS_0_NAME=local
KAFKA_CLUSTERS_0_BOOTSTRAPSERVERS=kafka:9092

# =============================================================================
# INFRASTRUCTURE - REDIS
# =============================================================================
# Redis connection URL (format: redis://host:port)
REDIS_URL=redis://redis:6379

# Redis host and port (for internal use)
REDIS_HOST=redis
REDIS_PORT=6379

# =============================================================================
# INFRASTRUCTURE - CASSANDRA
# =============================================================================
# Cassandra cluster configuration
CASSANDRA_HOSTS=cassandra
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=chat
CASSANDRA_CLUSTER_NAME=chat-cluster
CASSANDRA_DC=dc1
CASSANDRA_RACK=rack1
CASSANDRA_ENDPOINT_SNITCH=GossipingPropertyFileSnitch

# Cassandra memory settings (increase for production)
MAX_HEAP_SIZE=512M
HEAP_NEWSIZE=128M

# =============================================================================
# INFRASTRUCTURE - MINIO (S3-Compatible Object Storage)
# =============================================================================
# MinIO endpoint (internal Docker network address)
MINIO_ENDPOINT=minio:9000

# MinIO access credentials (CHANGE THESE IN PRODUCTION!)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your-secret-key-here-change-in-production
MINIO_ACCESS_KEY=your-secret-key-here-change-in-production
MINIO_SECRET_KEY=your-secret-key-here-change-in-production

# MinIO bucket for chat files
MINIO_BUCKET=chat-files

# MinIO SSL configuration (true/false)
MINIO_USE_SSL=false

# =============================================================================
# MICROSERVICES - API GATEWAY
# =============================================================================
# API Gateway port (external access)
API_GATEWAY_PORT=8000

# Internal service URLs for API Gateway
USER_SERVICE_GRPC=user-service:50051
CHAT_SERVICE_WS=ws://chat-service:8001
CHAT_SERVICE_URL=http://chat-service:8001
ORDER_SERVICE_URL=http://order-service:8002
NOTIFICATION_SERVICE_URL=http://notification-service:8003
MESSAGE_PERSISTENCE_SERVICE_URL=http://message-persistence-service:8004

# =============================================================================
# MICROSERVICES - USER SERVICE (gRPC)
# =============================================================================
# gRPC server port
USER_SERVICE_PORT=50051
GRPC_PORT=50051

# =============================================================================
# MICROSERVICES - CHAT SERVICE (WebSocket)
# =============================================================================
# Chat service HTTP/WebSocket port
CHAT_SERVICE_PORT=8001

# Chat service scaling port range (for horizontal scaling)
CHAT_SERVICE_PORT_RANGE=8010-8019

# =============================================================================
# MICROSERVICES - ORDER SERVICE (REST + Kafka)
# =============================================================================
# Order service HTTP port
ORDER_SERVICE_PORT=8002

# Order service scaling port range (for horizontal scaling)
ORDER_SERVICE_PORT_RANGE=8020-8029

# =============================================================================
# MICROSERVICES - NOTIFICATION SERVICE (Kafka Consumer + SSE)
# =============================================================================
# Notification service HTTP/SSE port
NOTIFICATION_SERVICE_PORT=8003

# Notification service scaling port range (for horizontal scaling)
NOTIFICATION_SERVICE_PORT_RANGE=8030-8039

# =============================================================================
# MICROSERVICES - MESSAGE PERSISTENCE SERVICE (Kafka Consumer + Cassandra)
# =============================================================================
# Message persistence service HTTP port
MESSAGE_PERSISTENCE_SERVICE_PORT=8004

# Message persistence service scaling port range (for horizontal scaling)
MESSAGE_PERSISTENCE_SERVICE_PORT_RANGE=8040-8049

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
# Application environment (development/staging/production)
ENVIRONMENT=development

# Log level (DEBUG/INFO/WARNING/ERROR/CRITICAL)
LOG_LEVEL=INFO

# Enable debug mode (true/false)
DEBUG=false

# =============================================================================
# EXTERNAL PORTS (Host Machine Access)
# =============================================================================
# These ports are exposed on your host machine

# Infrastructure
KAFKA_EXTERNAL_PORT=9092
KAFKA_CONTROLLER_PORT=9093
KAFKA_UI_PORT=8080
REDIS_EXTERNAL_PORT=6379
REDIS_UI_PORT=5540
CASSANDRA_EXTERNAL_PORT=9042
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Services
API_GATEWAY_EXTERNAL_PORT=8000
USER_SERVICE_EXTERNAL_PORT=50051
CHAT_SERVICE_EXTERNAL_PORT=8011
ORDER_SERVICE_EXTERNAL_PORT=8002
NOTIFICATION_SERVICE_EXTERNAL_PORT=8003
MESSAGE_PERSISTENCE_EXTERNAL_PORT=8004

# =============================================================================
# PERFORMANCE TUNING
# =============================================================================
# Uvicorn workers (increase for production)
WORKERS=1

# Request timeout (seconds)
REQUEST_TIMEOUT=30

# WebSocket ping interval (seconds)
WEBSOCKET_PING_INTERVAL=30

# SSE heartbeat interval (seconds)
SSE_HEARTBEAT_INTERVAL=30

# Redis message history size (number of messages to cache per room)
REDIS_HISTORY_SIZE=10

# Cassandra query page size
CASSANDRA_PAGE_SIZE=100

# Kafka consumer group ID prefixes
KAFKA_NOTIFICATION_CONSUMER_GROUP=notification-service
KAFKA_PERSISTENCE_CONSUMER_GROUP=message-persistence-service

# =============================================================================
# HEALTH CHECK CONFIGURATION
# =============================================================================
# Health check intervals (seconds)
HEALTH_CHECK_INTERVAL=10
HEALTH_CHECK_TIMEOUT=5
HEALTH_CHECK_RETRIES=5
HEALTH_CHECK_START_PERIOD=10

# Kafka health check start period (needs more time to initialize)
KAFKA_HEALTH_CHECK_START_PERIOD=30

# Cassandra health check start period (needs more time to initialize)
CASSANDRA_HEALTH_CHECK_START_PERIOD=60

# =============================================================================
# SECURITY (CHANGE IN PRODUCTION!)
# =============================================================================
# JWT secret key (for authentication, if implemented)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-secret-key-here-change-in-production

# API keys (if implementing API key authentication)
API_KEY=your-api-key-here

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:8000,http://localhost:3000

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable/disable features (true/false)
ENABLE_METRICS=true
ENABLE_TRACING=false
ENABLE_FILE_UPLOAD=true
ENABLE_MESSAGE_PERSISTENCE=true
